<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>DraftCopaDoMundo.SaveEditor</RootNamespace>
    <StartupObject>DraftCopaDoMundo.SaveEditor.ImportForm</StartupObject>
    <AssemblyName>Draft-Copa-Do-Mundo-SaveEditor</AssemblyName>
    <RollForward>Major</RollForward>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <ApplicationIcon>draft-copa.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="FifaLibrary19">
      <HintPath>FifaLibrary19.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
